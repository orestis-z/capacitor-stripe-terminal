{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "declaration": true,
    "experimentalDecorators": true,
    "lib": ["dom", "es2017"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "rootDir": "src",
    "outDir": "dist/esm",
    "sourceMap": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2017"
  },
  "files": ["src/index.ts"]
}
